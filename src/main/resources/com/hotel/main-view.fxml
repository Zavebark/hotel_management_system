<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx/13"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hotel.controller.MainController"
            styleClass="root-pane"
            prefWidth="1200" prefHeight="750">

    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <!-- ══════ HEADER ══════ -->
    <top>
        <HBox styleClass="header" alignment="CENTER_LEFT" spacing="12">
            <padding><Insets top="16" right="28" bottom="16" left="28"/></padding>
            <Label text="✦" style="-fx-font-size: 20px; -fx-text-fill: #3b82f6;"/>
            <VBox spacing="1">
                <Label text="HOTEL LUMIÈRE" styleClass="header-title"/>
                <Label text="Premium Hotel Management System" styleClass="header-sub"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label text="LIVE" styleClass="live-badge"/>
            </VBox>
        </HBox>
    </top>

    <!-- ══════ TABS ══════ -->
    <center>
        <TabPane fx:id="mainTabPane" styleClass="main-tabs"
                 tabClosingPolicy="UNAVAILABLE">

            <!-- ═══ DASHBOARD ═══ -->
            <Tab text="  📊  Dashboard  ">
                <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                    <VBox spacing="20">
                        <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>

                        <HBox spacing="16">
                            <VBox styleClass="stat-card"
                                  HBox.hgrow="ALWAYS"
                                  maxWidth="1.7976931348623157E308">
                                <Label text="GUESTS IN-HOUSE" styleClass="stat-label"/>
                                <Label fx:id="lblTotalGuests" text="0" styleClass="stat-value"/>
                            </VBox>
                            <VBox styleClass="stat-card-amber"
                                  HBox.hgrow="ALWAYS"
                                  maxWidth="1.7976931348623157E308">
                                <Label text="ROOMS OCCUPIED" styleClass="stat-label"/>
                                <Label fx:id="lblOccupied" text="0" styleClass="stat-value"/>
                            </VBox>
                            <VBox styleClass="stat-card-green"
                                  HBox.hgrow="ALWAYS"
                                  maxWidth="1.7976931348623157E308">
                                <Label text="ROOMS AVAILABLE" styleClass="stat-label"/>
                                <Label fx:id="lblAvailable" text="0" styleClass="stat-value"/>
                            </VBox>
                            <VBox styleClass="stat-card-violet"
                                  HBox.hgrow="ALWAYS"
                                  maxWidth="1.7976931348623157E308">
                                <Label text="TOTAL REVENUE" styleClass="stat-label"/>
                                <Label fx:id="lblRevenue" text="₹0" styleClass="stat-value"/>
                            </VBox>
                        </HBox>

                        <VBox styleClass="card" spacing="16">
                            <Label text="Occupancy by Room Type" styleClass="section-title"/>
                            <GridPane hgap="16" vgap="12">
                                <Label text="Classic Room" styleClass="room-type-label"
                                       GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <ProgressBar fx:id="pbSS" progress="0"
                                             maxWidth="1.7976931348623157E308"
                                             GridPane.columnIndex="1" GridPane.rowIndex="0"
                                             GridPane.hgrow="ALWAYS"/>
                                <Label fx:id="lblSSStat" text="0 / 300 (0%)"
                                       styleClass="room-stat"
                                       GridPane.columnIndex="2" GridPane.rowIndex="0"/>

                                <Label text="Superior Room" styleClass="room-type-label"
                                       GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <ProgressBar fx:id="pbSD" progress="0"
                                             styleClass="progress-rd"
                                             maxWidth="1.7976931348623157E308"
                                             GridPane.columnIndex="1" GridPane.rowIndex="1"
                                             GridPane.hgrow="ALWAYS"/>
                                <Label fx:id="lblSDStat" text="0 / 300 (0%)"
                                       styleClass="room-stat"
                                       GridPane.columnIndex="2" GridPane.rowIndex="1"/>

                                <Label text="Lumière Suite" styleClass="room-type-label"
                                       GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <ProgressBar fx:id="pbDS" progress="0"
                                             styleClass="progress-ds"
                                             maxWidth="1.7976931348623157E308"
                                             GridPane.columnIndex="1" GridPane.rowIndex="2"
                                             GridPane.hgrow="ALWAYS"/>
                                <Label fx:id="lblDSStat" text="0 / 200 (0%)"
                                       styleClass="room-stat"
                                       GridPane.columnIndex="2" GridPane.rowIndex="2"/>

                                <Label text="Grand Lumière" styleClass="room-type-label"
                                       GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                                <ProgressBar fx:id="pbGS" progress="0"
                                             styleClass="progress-dd"
                                             maxWidth="1.7976931348623157E308"
                                             GridPane.columnIndex="1" GridPane.rowIndex="3"
                                             GridPane.hgrow="ALWAYS"/>
                                <Label fx:id="lblGSStat" text="0 / 150 (0%)"
                                       styleClass="room-stat"
                                       GridPane.columnIndex="2" GridPane.rowIndex="3"/>

                                <Label text="Penthouse" styleClass="room-type-label"
                                       GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                                <ProgressBar fx:id="pbPS" progress="0"
                                             maxWidth="1.7976931348623157E308"
                                             GridPane.columnIndex="1" GridPane.rowIndex="4"
                                             GridPane.hgrow="ALWAYS"/>
                                <Label fx:id="lblPSStat" text="0 / 50 (0%)"
                                       styleClass="room-stat"
                                       GridPane.columnIndex="2" GridPane.rowIndex="4"/>

                                <columnConstraints>
                                    <ColumnConstraints minWidth="160" maxWidth="160"/>
                                    <ColumnConstraints hgrow="ALWAYS" fillWidth="true"/>
                                    <ColumnConstraints minWidth="150" maxWidth="170"/>
                                </columnConstraints>
                            </GridPane>
                        </VBox>

                        <VBox styleClass="card" spacing="12">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label text="Current Guests" styleClass="section-title"
                                       HBox.hgrow="ALWAYS"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <TextField fx:id="searchField"
                                           promptText="🔍  Search guest by name..."
                                           styleClass="search-box"
                                           onKeyReleased="#onSearchGuest"/>
                            </HBox>
                            <TableView fx:id="guestTable" styleClass="hotel-table"
                                       prefHeight="300">
                                <columns>
                                    <TableColumn fx:id="colGuestRoom"
                                                 text="Room" prefWidth="70"/>
                                    <TableColumn fx:id="colGuestName"
                                                 text="Guest Name" prefWidth="170"/>
                                    <TableColumn fx:id="colGuestPhone"
                                                 text="Phone" prefWidth="130"/>
                                    <TableColumn fx:id="colGuestType"
                                                 text="Room Type" prefWidth="150"/>
                                    <TableColumn fx:id="colGuestNights"
                                                 text="Nights" prefWidth="70"/>
                                    <TableColumn fx:id="colGuestCheckIn"
                                                 text="Check-In" prefWidth="180"/>
                                    <TableColumn fx:id="colGuestServices"
                                                 text="Services" prefWidth="180"/>
                                </columns>
                                <placeholder>
                                    <Label text="No guests currently checked in."
                                           styleClass="placeholder-text"/>
                                </placeholder>
                            </TableView>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </Tab>

            <!-- ═══ BOOKING ═══ -->
            <Tab text="  🛏  Booking  ">
                <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                    <VBox spacing="24">
                        <padding>
                            <Insets top="32" right="180" bottom="32" left="180"/>
                        </padding>

                        <Label text="Reserve a Room" styleClass="page-title"/>
                        <Label text="Select a room category and complete guest details."
                               styleClass="page-sub"/>

                        <VBox styleClass="card" spacing="16">
                            <Label text="Step 1 — Select Room Category"
                                   styleClass="section-title"/>
                            <HBox spacing="12">
                                <VBox fx:id="chipSS" styleClass="room-select-chip"
                                      HBox.hgrow="ALWAYS" minWidth="160"
                                      maxWidth="1.7976931348623157E308"
                                      onMouseClicked="#onSelectRoomType">
                                    <Label text="Classic Room" styleClass="rate-chip-label" wrapText="true"/>
                                    <Label text="₹1,800 / night" styleClass="rate-chip-price" wrapText="true"/>
                                    <Label fx:id="availSS" text="" styleClass="chip-avail"/>
                                </VBox>
                                <VBox fx:id="chipSD" styleClass="room-select-chip"
                                      HBox.hgrow="ALWAYS" minWidth="160"
                                      maxWidth="1.7976931348623157E308"
                                      onMouseClicked="#onSelectRoomType">
                                    <Label text="Superior Room" styleClass="rate-chip-label" wrapText="true"/>
                                    <Label text="₹3,200 / night" styleClass="rate-chip-price" wrapText="true"/>
                                    <Label fx:id="availSD" text="" styleClass="chip-avail"/>
                                </VBox>
                                <VBox fx:id="chipDS" styleClass="room-select-chip"
                                      HBox.hgrow="ALWAYS" minWidth="160"
                                      maxWidth="1.7976931348623157E308"
                                      onMouseClicked="#onSelectRoomType">
                                    <Label text="Lumière Suite" styleClass="rate-chip-label" wrapText="true"/>
                                    <Label text="₹5,500 / night" styleClass="rate-chip-price" wrapText="true"/>
                                    <Label fx:id="availDS" text="" styleClass="chip-avail"/>
                                </VBox>
                                <VBox fx:id="chipGS" styleClass="room-select-chip"
                                      HBox.hgrow="ALWAYS" minWidth="160"
                                      maxWidth="1.7976931348623157E308"
                                      onMouseClicked="#onSelectRoomType">
                                    <Label text="Grand Lumière" styleClass="rate-chip-label" wrapText="true"/>
                                    <Label text="₹8,500 / night" styleClass="rate-chip-price" wrapText="true"/>
                                    <Label fx:id="availGS" text="" styleClass="chip-avail"/>
                                </VBox>
                                <VBox fx:id="chipPS" styleClass="room-select-chip"
                                      HBox.hgrow="ALWAYS" minWidth="160"
                                      maxWidth="1.7976931348623157E308"
                                      onMouseClicked="#onSelectRoomType">
                                    <Label text="Penthouse" styleClass="rate-chip-label" wrapText="true"/>
                                    <Label text="₹18,000 / night" styleClass="rate-chip-price" wrapText="true"/>
                                    <Label fx:id="availPS" text="" styleClass="chip-avail"/>
                                </VBox>
                            </HBox>
                            <Label fx:id="bookRoomInfoLabel"
                                   text="← Select a room category to continue"
                                   styleClass="info-label"/>
                        </VBox>

                        <VBox styleClass="card" spacing="14">
                            <Label text="Step 2 — Guest Details" styleClass="section-title"/>
                            <GridPane hgap="16" vgap="14">
                                <Label text="Guest Name *" styleClass="form-label"
                                       GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <TextField fx:id="bookNameField" promptText="Full name"
                                           styleClass="hotel-input"
                                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                <Label text="Phone" styleClass="form-label"
                                       GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <TextField fx:id="bookPhoneField"
                                           promptText="Contact number (optional)"
                                           styleClass="hotel-input"
                                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                <Label text="Nights *" styleClass="form-label"
                                       GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <TextField fx:id="bookDaysField"
                                           promptText="Number of nights"
                                           styleClass="hotel-input"
                                           GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                <columnConstraints>
                                    <ColumnConstraints minWidth="160"/>
                                    <ColumnConstraints hgrow="ALWAYS" fillWidth="true"/>
                                </columnConstraints>
                            </GridPane>
                        </VBox>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Button text="✓  Confirm Reservation"
                                    styleClass="btn-primary" onAction="#onBookRoom"/>
                            <Label fx:id="bookStatusLabel" text=""
                                   styleClass="status-label" wrapText="true"/>
                        </HBox>
                    </VBox>
                </ScrollPane>
            </Tab>

            <!-- ═══ SERVICES ═══ -->
            <Tab text="  ❋  Services  ">
                <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                    <VBox spacing="24">
                        <padding>
                            <Insets top="32" right="180" bottom="32" left="180"/>
                        </padding>

                        <Label text="Housekeeping &amp; Services" styleClass="page-title"/>
                        <Label text="Add paid services to a guest's room. These will be included in their final bill."
                               styleClass="page-sub"/>

                        <VBox styleClass="card" spacing="14">
                            <Label text="Step 1 — Find Guest Room" styleClass="section-title"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <TextField fx:id="serviceRoomField"
                                           promptText="Enter room number"
                                           styleClass="hotel-input" prefWidth="220"/>
                                <Button text="Look Up" styleClass="btn-secondary"
                                        onAction="#onLookupServiceRoom"/>
                            </HBox>
                            <Label fx:id="serviceGuestLabel" text=""
                                   styleClass="info-label" wrapText="true"/>
                        </VBox>

                        <VBox styleClass="card" spacing="14">
                            <Label text="Step 2 — Select Service" styleClass="section-title"/>
                            <HBox spacing="12">
                                <VBox fx:id="svcCleaning" styleClass="service-chip"
                                      HBox.hgrow="ALWAYS"
                                      maxWidth="1.7976931348623157E308"
                                      onMouseClicked="#onAddService">
                                    <Label text="🧹  Room Cleaning" styleClass="service-name"/>
                                    <Label text="₹200" styleClass="service-price"/>
                                </VBox>
                                <VBox fx:id="svcLaundry" styleClass="service-chip"
                                      HBox.hgrow="ALWAYS"
                                      maxWidth="1.7976931348623157E308"
                                      onMouseClicked="#onAddService">
                                    <Label text="👕  Laundry" styleClass="service-name"/>
                                    <Label text="₹350" styleClass="service-price"/>
                                </VBox>
                                <VBox fx:id="svcRoomService" styleClass="service-chip"
                                      HBox.hgrow="ALWAYS"
                                      maxWidth="1.7976931348623157E308"
                                      onMouseClicked="#onAddService">
                                    <Label text="🍽  Room Service" styleClass="service-name"/>
                                    <Label text="₹500" styleClass="service-price"/>
                                </VBox>
                            </HBox>
                            <HBox spacing="12">
                                <VBox fx:id="svcSpa" styleClass="service-chip"
                                      HBox.hgrow="ALWAYS"
                                      maxWidth="1.7976931348623157E308"
                                      onMouseClicked="#onAddService">
                                    <Label text="💆  Spa Access" styleClass="service-name"/>
                                    <Label text="₹1,200" styleClass="service-price"/>
                                </VBox>
                                <VBox fx:id="svcTransfer" styleClass="service-chip"
                                      HBox.hgrow="ALWAYS"
                                      maxWidth="1.7976931348623157E308"
                                      onMouseClicked="#onAddService">
                                    <Label text="🚗  Airport Transfer" styleClass="service-name"/>
                                    <Label text="₹800" styleClass="service-price"/>
                                </VBox>
                                <VBox fx:id="svcExtraBed" styleClass="service-chip"
                                      HBox.hgrow="ALWAYS"
                                      maxWidth="1.7976931348623157E308"
                                      onMouseClicked="#onAddService">
                                    <Label text="🛏  Extra Bed" styleClass="service-name"/>
                                    <Label text="₹600" styleClass="service-price"/>
                                </VBox>
                            </HBox>
                            <Label fx:id="serviceStatusLabel" text="" styleClass="status-label"/>
                        </VBox>

                        <VBox styleClass="card" spacing="12">
                            <Label text="Services Added for This Room" styleClass="section-title"/>
                            <TableView fx:id="serviceTable" styleClass="hotel-table"
                                       prefHeight="200">
                                <columns>
                                    <TableColumn fx:id="colSvcRoom" text="Room" prefWidth="80"/>
                                    <TableColumn fx:id="colSvcName" text="Service" prefWidth="200"/>
                                    <TableColumn fx:id="colSvcPrice" text="Price (₹)" prefWidth="120"/>
                                    <TableColumn fx:id="colSvcStatus" text="Status" prefWidth="120"/>
                                </columns>
                                <placeholder>
                                    <Label text="No services added yet." styleClass="placeholder-text"/>
                                </placeholder>
                            </TableView>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </Tab>

            <!-- ═══ CHECKOUT ═══ -->
            <Tab text="  🔑  Checkout  ">
                <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                    <VBox spacing="24">
                        <padding>
                            <Insets top="32" right="180" bottom="32" left="180"/>
                        </padding>

                        <Label text="Guest Checkout" styleClass="page-title"/>
                        <Label text="Look up the room to view the itemized bill, then confirm checkout."
                               styleClass="page-sub"/>

                        <VBox styleClass="card" spacing="14">
                            <Label text="Step 1 — Look Up Room" styleClass="section-title"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <TextField fx:id="checkoutRoomField"
                                           promptText="Room number"
                                           styleClass="hotel-input" prefWidth="220"/>
                                <Button text="Find Guest" styleClass="btn-secondary"
                                        onAction="#onLookupCheckout"/>
                            </HBox>
                            <Label fx:id="checkoutGuestLabel" text=""
                                   styleClass="info-label" wrapText="true"/>
                        </VBox>

                        <VBox styleClass="card" spacing="12">
                            <Label text="Step 2 — Bill Summary" styleClass="section-title"/>
                            <VBox fx:id="billItemsBox" spacing="8"/>
                            <HBox alignment="CENTER_RIGHT">
                                <Label fx:id="lblBillTotal" text="" styleClass="bill-total"/>
                            </HBox>
                            <Label text="Actual nights stayed (leave blank to use booked):"
                                   styleClass="hint-label"/>
                            <TextField fx:id="checkoutDaysField"
                                       promptText="Override nights (optional)"
                                       styleClass="hotel-input" prefWidth="260"/>
                        </VBox>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Button text="🔑  Confirm Checkout &amp; Generate Bill"
                                    styleClass="btn-danger" onAction="#onCheckout"/>
                            <Label fx:id="checkoutStatusLabel" text=""
                                   styleClass="status-label" wrapText="true"/>
                        </HBox>
                    </VBox>
                </ScrollPane>
            </Tab>

            <!-- ═══ BILLING ═══ -->
            <Tab text="  💳  Billing  ">
                <VBox spacing="20">
                    <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>

                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <Label text="Billing History" styleClass="page-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <VBox styleClass="revenue-chip" alignment="CENTER_RIGHT">
                            <Label text="TOTAL REVENUE" styleClass="stat-label"/>
                            <Label fx:id="lblTotalRevenue" text="₹0" styleClass="revenue-value"/>
                        </VBox>
                    </HBox>

                    <TableView fx:id="billingTable" styleClass="hotel-table"
                               VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colBillDate" text="Checkout Date" prefWidth="170"/>
                            <TableColumn fx:id="colBillRoom" text="Room" prefWidth="70"/>
                            <TableColumn fx:id="colBillGuest" text="Guest Name" prefWidth="150"/>
                            <TableColumn fx:id="colBillPhone" text="Phone" prefWidth="120"/>
                            <TableColumn fx:id="colBillType" text="Room Type" prefWidth="140"/>
                            <TableColumn fx:id="colBillNights" text="Nights" prefWidth="70"/>
                            <TableColumn fx:id="colBillRoomAmt" text="Room Charges" prefWidth="120"/>
                            <TableColumn fx:id="colBillSvcAmt" text="Services" prefWidth="100"/>
                            <TableColumn fx:id="colBillTotal" text="Total Bill" prefWidth="110"/>
                        </columns>
                        <placeholder>
                            <Label text="No billing records yet." styleClass="placeholder-text"/>
                        </placeholder>
                    </TableView>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>