<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hotel.controller.MainController"
      prefWidth="1000" prefHeight="680">

    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <!-- ── Sidebar ── -->
    <VBox styleClass="sidebar" spacing="0">

        <!-- Hotel Branding -->
        <Label text="✦ ESTABLISHED 1932 ✦" styleClass="sidebar-title"/>
        <Label text="The Grand Budapest Hotel" styleClass="sidebar-hotel-name"/>

        <Region styleClass="sidebar-divider" minHeight="1" maxHeight="1"/>

        <!-- Nav Buttons -->
        <Button fx:id="btnNavDashboard" text="⊞  Dashboard"
                styleClass="sidebar-btn, sidebar-btn-active"
                onAction="#showDashboard" maxWidth="Infinity"/>
        <Button fx:id="btnNavRooms" text="▦  Rooms"
                styleClass="sidebar-btn"
                onAction="#showRooms" maxWidth="Infinity"/>
        <Button fx:id="btnNavCustomers" text="✦  Guests"
                styleClass="sidebar-btn"
                onAction="#showCustomers" maxWidth="Infinity"/>
        <Button fx:id="btnNavBookings" text="◈  Bookings"
                styleClass="sidebar-btn"
                onAction="#showBookings" maxWidth="Infinity"/>
        <Button fx:id="btnNavServices" text="❋  Services"
                styleClass="sidebar-btn"
                onAction="#showServices" maxWidth="Infinity"/>

        <!-- Spacer -->
        <Region VBox.vgrow="ALWAYS"/>

        <Region styleClass="sidebar-divider" minHeight="1" maxHeight="1"/>
        <Label text="Concierge System v1.0"
               style="-fx-text-fill: #5D4037; -fx-font-size: 10px;
                      -fx-padding: 10px 15px;"/>
    </VBox>

    <!-- ── Main Content ── -->
    <VBox HBox.hgrow="ALWAYS" spacing="0">

        <!-- Header -->
        <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="10">
            <VBox>
                <Label fx:id="lblPageTitle" text="Dashboard"
                       styleClass="header-title"/>
                <Label text="Welcome back, Concierge."
                       styleClass="header-subtitle"/>
            </VBox>
        </HBox>

        <!-- Page Stack — only one visible at a time -->
        <StackPane VBox.vgrow="ALWAYS">

            <!-- ══════════ DASHBOARD ══════════ -->
            <ScrollPane fx:id="pageDashboard" fitToWidth="true"
                        style="-fx-background-color: #F5F0E8;">
                <VBox styleClass="content-area" spacing="20">

                    <Label text="— Overview —" styleClass="section-title"/>
                    <Region styleClass="section-divider" minHeight="2" maxHeight="2"/>

                    <!-- Stat Cards -->
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <VBox styleClass="stat-card" spacing="5">
                            <Label fx:id="lblTotalRooms" text="0"
                                   styleClass="stat-card-value"/>
                            <Label text="TOTAL ROOMS"
                                   styleClass="stat-card-label"/>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="5">
                            <Label fx:id="lblOccupied" text="0"
                                   styleClass="stat-card-value"/>
                            <Label text="OCCUPIED"
                                   styleClass="stat-card-label"/>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="5">
                            <Label fx:id="lblAvailable" text="0"
                                   styleClass="stat-card-value"/>
                            <Label text="AVAILABLE"
                                   styleClass="stat-card-label"/>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="5">
                            <Label fx:id="lblTotalGuests" text="0"
                                   styleClass="stat-card-value"/>
                            <Label text="TOTAL GUESTS"
                                   styleClass="stat-card-label"/>
                        </VBox>
                        <VBox styleClass="stat-card-revenue" spacing="5">
                            <Label fx:id="lblRevenue" text="Rs.0"
                                   styleClass="stat-card-value"/>
                            <Label text="TOTAL REVENUE"
                                   styleClass="stat-card-label"/>
                        </VBox>
                    </HBox>

                    <Label text="— Active Bookings —" styleClass="section-title"/>
                    <Region styleClass="section-divider" minHeight="2" maxHeight="2"/>

                    <TableView fx:id="dashboardBookingTable" prefHeight="250">
                        <columns>
                            <TableColumn fx:id="dashColBookingId"
                                         text="Booking ID" prefWidth="100"/>
                            <TableColumn fx:id="dashColRoom"
                                         text="Room" prefWidth="80"/>
                            <TableColumn fx:id="dashColGuest"
                                         text="Guest" prefWidth="180"/>
                            <TableColumn fx:id="dashColCheckIn"
                                         text="Check-In" prefWidth="120"/>
                            <TableColumn fx:id="dashColCheckOut"
                                         text="Check-Out" prefWidth="120"/>
                            <TableColumn fx:id="dashColTotal"
                                         text="Total (Rs.)" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>
            </ScrollPane>

            <!-- ══════════ ROOMS ══════════ -->
            <ScrollPane fx:id="pageRooms" fitToWidth="true"
                        visible="false"
                        style="-fx-background-color: #F5F0E8;">
                <VBox styleClass="content-area" spacing="15">

                    <Label text="— Room Management —" styleClass="section-title"/>
                    <Region styleClass="section-divider" minHeight="2" maxHeight="2"/>

                    <!-- Add Room Form -->
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <VBox spacing="5">
                            <Label text="ROOM NUMBER" styleClass="form-label"/>
                            <TextField fx:id="txtRoomNumber"
                                       promptText="e.g. 101"
                                       styleClass="text-field"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="ROOM TYPE" styleClass="form-label"/>
                            <ComboBox fx:id="cmbRoomType"
                                      promptText="Select type"
                                      styleClass="combo-box"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="PRICE / NIGHT (Rs.)" styleClass="form-label"/>
                            <TextField fx:id="txtRoomPrice"
                                       promptText="e.g. 2500"
                                       styleClass="text-field"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text=" " styleClass="form-label"/>
                            <Button text="Add Room" styleClass="btn-primary"
                                    onAction="#handleAddRoom"/>
                        </VBox>
                    </HBox>

                    <Label fx:id="lblRoomMessage"/>

                    <Region styleClass="section-divider" minHeight="2" maxHeight="2"/>

                    <!-- Filter Bar -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button text="All Rooms" styleClass="btn-secondary"
                                onAction="#handleShowAllRooms"/>
                        <Button text="Available Only" styleClass="btn-gold"
                                onAction="#handleShowAvailableRooms"/>
                        <ComboBox fx:id="cmbFilterType"
                                  promptText="Filter by type"
                                  styleClass="combo-box"
                                  onAction="#handleFilterByType"/>
                    </HBox>

                    <TableView fx:id="roomTable" prefHeight="300">
                        <columns>
                            <TableColumn fx:id="colRoomNumber"
                                         text="Room No." prefWidth="100"/>
                            <TableColumn fx:id="colRoomType"
                                         text="Type" prefWidth="150"/>
                            <TableColumn fx:id="colRoomPrice"
                                         text="Price/Night" prefWidth="150"/>
                            <TableColumn fx:id="colRoomStatus"
                                         text="Status" prefWidth="120"/>
                            <TableColumn fx:id="colRoomDelete"
                                         text="Action" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
            </ScrollPane>

            <!-- ══════════ CUSTOMERS ══════════ -->
            <ScrollPane fx:id="pageCustomers" fitToWidth="true"
                        visible="false"
                        style="-fx-background-color: #F5F0E8;">
                <VBox styleClass="content-area" spacing="15">

                    <Label text="— Guest Registry —" styleClass="section-title"/>
                    <Region styleClass="section-divider" minHeight="2" maxHeight="2"/>

                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <VBox spacing="5">
                            <Label text="GUEST NAME" styleClass="form-label"/>
                            <TextField fx:id="txtCustomerName"
                                       promptText="Full name"
                                       styleClass="text-field"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="CONTACT NUMBER" styleClass="form-label"/>
                            <TextField fx:id="txtCustomerContact"
                                       promptText="Phone number"
                                       styleClass="text-field"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text=" " styleClass="form-label"/>
                            <Button text="Register Guest"
                                    styleClass="btn-primary"
                                    onAction="#handleAddCustomer"/>
                        </VBox>
                    </HBox>

                    <Label fx:id="lblCustomerMessage"/>

                    <Region styleClass="section-divider" minHeight="2" maxHeight="2"/>

                    <TableView fx:id="customerTable" prefHeight="350">
                        <columns>
                            <TableColumn fx:id="colCustomerId"
                                         text="Guest ID" prefWidth="100"/>
                            <TableColumn fx:id="colCustomerName"
                                         text="Name" prefWidth="220"/>
                            <TableColumn fx:id="colCustomerContact"
                                         text="Contact" prefWidth="200"/>
                            <TableColumn fx:id="colCustomerDelete"
                                         text="Action" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
            </ScrollPane>

            <!-- ══════════ BOOKINGS ══════════ -->
            <ScrollPane fx:id="pageBookings" fitToWidth="true"
                        visible="false"
                        style="-fx-background-color: #F5F0E8;">
                <VBox styleClass="content-area" spacing="15">

                    <Label text="— Reservations —" styleClass="section-title"/>
                    <Region styleClass="section-divider" minHeight="2" maxHeight="2"/>

                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <VBox spacing="5">
                            <Label text="GUEST ID" styleClass="form-label"/>
                            <TextField fx:id="txtBookingCustomerId"
                                       promptText="Guest ID"
                                       styleClass="text-field"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="ROOM" styleClass="form-label"/>
                            <ComboBox fx:id="cmbBookingRoom"
                                      promptText="Available rooms"
                                      styleClass="combo-box"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="CHECK-IN" styleClass="form-label"/>
                            <TextField fx:id="txtCheckIn"
                                       promptText="DD/MM/YYYY"
                                       styleClass="text-field"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="CHECK-OUT" styleClass="form-label"/>
                            <TextField fx:id="txtCheckOut"
                                       promptText="DD/MM/YYYY"
                                       styleClass="text-field"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="NIGHTS" styleClass="form-label"/>
                            <TextField fx:id="txtNights"
                                       promptText="e.g. 3"
                                       styleClass="text-field"
                                       prefWidth="80"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text=" " styleClass="form-label"/>
                            <Button text="Reserve Room"
                                    styleClass="btn-primary"
                                    onAction="#handleBookRoom"/>
                        </VBox>
                    </HBox>

                    <Label fx:id="lblBookingMessage"/>

                    <Region styleClass="section-divider" minHeight="2" maxHeight="2"/>

                    <Label text="— Active Reservations —" styleClass="section-title"/>

                    <TableView fx:id="bookingTable" prefHeight="250">
                        <columns>
                            <TableColumn fx:id="colBookingId"
                                         text="ID" prefWidth="60"/>
                            <TableColumn fx:id="colBookingRoom"
                                         text="Room" prefWidth="80"/>
                            <TableColumn fx:id="colBookingCustomer"
                                         text="Guest" prefWidth="160"/>
                            <TableColumn fx:id="colBookingCheckIn"
                                         text="Check-In" prefWidth="110"/>
                            <TableColumn fx:id="colBookingCheckOut"
                                         text="Check-Out" prefWidth="110"/>
                            <TableColumn fx:id="colBookingTotal"
                                         text="Total (Rs.)" prefWidth="110"/>
                        </columns>
                    </TableView>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="txtCheckoutId"
                                   promptText="Enter Booking ID to checkout"
                                   styleClass="text-field"/>
                        <Button text="Checkout Guest"
                                styleClass="btn-danger"
                                onAction="#handleCheckout"/>
                    </HBox>
                </VBox>
            </ScrollPane>

            <!-- ══════════ SERVICES ══════════ -->
            <ScrollPane fx:id="pageServices" fitToWidth="true"
                        visible="false"
                        style="-fx-background-color: #F5F0E8;">
                <VBox styleClass="content-area" spacing="15">

                    <Label text="— Housekeeping &amp; Services —"
                           styleClass="section-title"/>
                    <Region styleClass="section-divider" minHeight="2" maxHeight="2"/>

                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <VBox spacing="5">
                            <Label text="ROOM NUMBER" styleClass="form-label"/>
                            <TextField fx:id="txtServiceRoom"
                                       promptText="Room no."
                                       styleClass="text-field"
                                       prefWidth="120"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="SERVICE TYPE" styleClass="form-label"/>
                            <ComboBox fx:id="cmbServiceType"
                                      promptText="Select service"
                                      styleClass="combo-box"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text=" " styleClass="form-label"/>
                            <Button text="Add Request"
                                    styleClass="btn-primary"
                                    onAction="#handleAddService"/>
                        </VBox>
                    </HBox>

                    <Label fx:id="lblServiceMessage"/>

                    <Region styleClass="section-divider" minHeight="2" maxHeight="2"/>

                    <TableView fx:id="serviceTable" prefHeight="350">
                        <columns>
                            <TableColumn fx:id="colServiceId"
                                         text="ID" prefWidth="60"/>
                            <TableColumn fx:id="colServiceRoom"
                                         text="Room" prefWidth="80"/>
                            <TableColumn fx:id="colServiceType"
                                         text="Service" prefWidth="180"/>
                            <TableColumn fx:id="colServiceStatus"
                                         text="Status" prefWidth="120"/>
                            <TableColumn fx:id="colServiceAction"
                                         text="Action" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>
            </ScrollPane>

        </StackPane>
    </VBox>
</HBox>